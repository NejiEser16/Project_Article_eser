    <property name="styleSheet">
     <string notr="true">/* 1. Main Background */
QMainWindow, QWidget#centralwidget {
    background-color: white;
}

/* 2. The Left Sidebar - Match the Navy exactly */
QFrame#frame { 
    background-color: #1a3a8a;
}

/* 3. The Sidebar Buttons */
QFrame#frame QPushButton {
    background-color: #1a3a8a;
    color: white;
    border: 1px solid white;
    border-radius: 4px;
}

/* 4. The Action Buttons (Nouveau, Enregistrer) */
QPushButton#pushButton_10, QPushButton#pushButton_2 { 
    background-color: #ff7e39;
    color: white;
    font-weight: bold;
    border-radius: 6px;
}

/* 5. Group Boxes (The Search and Stats boxes) */
QGroupBox {
    border: 1px solid #1a3a8a;
    color: #1a3a8a;
    background-color: #f9f9f9;
}

/* 6. The Table Headers */
QHeaderView::section {
    background-color: #1a3a8a;
    color: white;
}</string>
