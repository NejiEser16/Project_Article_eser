     <property name="styleSheet">
      <string notr="true">/* Forces the background of the entire table area to white */
QTableView {
    background-color: white;
    alternate-background-color: white;
    gridline-color: #d1d5db;
    color: black;
}

/* Forces the empty space below the rows to also be white */
QTableView QTableCornerButton::section {
    background-color: white;
}

/* Keeps your navy blue headers */
QHeaderView::section {
    background-color: #1a3a8a;
    color: white;
    font-weight: bold;
    border: 1px solid white;
}</string>
