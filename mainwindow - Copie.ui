  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #0f172a; /* Deep modern navy */
}
QGroupBox {
    background-color: rgba(255, 255, 255, 15);
    border: 1px solid rgba(255, 255, 255, 30);
    border-radius: 10px;
    color: white;
}
QLabel {
    color: #1a3a8a;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #e66a2e; /* Turns a darker orange on hover */
}
QPushButton:pressed {
    background-color: #cc5a24; /* Turns even darker when clicked */
}</string>
  </property>
